inventario = [
    {"nombre": "Pan", "precio": 1500, "stock": 30},
    {"nombre": "Leche", "precio": 3500, "stock": 15},
    {"nombre": "Café", "precio": 8000, "stock": 10},
]

# 1. Muestra el nombre del primer producto
# Entramos al primer cajón [0] y leemos la etiqueta "nombre"
print(f"Primer producto: {inventario[0]['nombre']}")

# 2. Agrega un nuevo producto
inventario.append({"nombre": "Huevos", "precio": 600, "stock": 12})

# 3. Disminuye el stock de "Leche" en 2 unidades
# Accedemos a la Leche (posición 1) y restamos al valor de la etiqueta "stock"
inventario[1]["stock"] -= 2

# 4. Calcula el valor total del inventario (precio * stock por producto)
valor_total = sum(p["precio"] * p["stock"] for p in inventario)
print(f"Valor total del inventario: ${valor_total}")

# 5. Muestra los productos con stock menor a 10
# (En este caso, agregaremos uno con stock bajo para probar)
inventario.append({"nombre": "Sal", "precio": 1000, "stock": 5})
bajos_en_stock = [p["nombre"] for p in inventario if p["stock"] < 10]
print(f"Productos con stock bajo (<10): {bajos_en_stock}")

# 6 y 7. Aumenta el precio en 10% y redondea
for p in inventario:
    p["precio"] = round(p["precio"] * 1.10, 2)

# 8. Busca un producto por nombre ingresado por el usuario
busqueda = input("Ingrese el nombre del producto a buscar: ").capitalize()
encontrado = None

for p in inventario:
    if p["nombre"] == busqueda:
        encontrado = p
        break

if encontrado:
    print(f"Producto encontrado: {encontrado}")
else:
    print("El producto no se encuentra en el inventario.")

# 9. Elimina un producto si su stock es 0
# Creamos una lista nueva solo con los que tienen stock mayor a 0
inventario = [p for p in inventario if p["stock"] > 0]

# 10. Ordena la lista por precio ascendente
# Usamos una función "lambda" que le dice al programa: "mira la etiqueta precio para ordenar"
inventario.sort(key=lambda p: p["precio"])

print("Inventario final ordenado por precio:")
for p in inventario:
    print(p)

