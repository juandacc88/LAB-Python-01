# Lista inicial de temperaturas
temperaturas = [22.5, 23.0, 21.8, 24.3, 25.1]

# 1. Agrega una nueva temperatura al final (por ejemplo, 26.0)
temperaturas.append(26.0)

# 2. Elimina la primera temperatura registrada (la que está en la posición 0)
temperaturas.pop(0)

# 3. Inserta una temperatura en la segunda posición (índice 1)
temperaturas.insert(1, 23.7)

# 4. Muestra la lista ordenada de menor a mayor
print("Lista ordenada:", sorted(temperaturas))

# 5. Diferencia entre la más alta y la más baja, y el promedio
maxima = max(temperaturas)
minima = min(temperaturas)
diferencia = maxima - minima
promedio = sum(temperaturas) / len(temperaturas)

print(f"Diferencia: {diferencia:.1f}°C")
print(f"Promedio: {promedio:.2f}°C")

# 6. Encuentra el índice (posición) de la temperatura 23.7
posicion = temperaturas.index(23.7)
print(f"La temperatura 23.7 está en la posición: {posicion}")

# 7. Muestra las temperaturas de la 2da a la 4ta posición
print("De la 2da a la 4ta posición:", temperaturas[1:4])

# 8. Muestra las tres primeras temperaturas
print("Las tres primeras:", temperaturas[:3])


